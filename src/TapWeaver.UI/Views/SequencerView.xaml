<UserControl x:Class="TapWeaver.UI.Views.SequencerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf">
    <UserControl.Resources>
        <Style x:Key="StepCellComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#223B82F6"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepCellComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ModernComboBoxStyle}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource StepCellComboBoxItemStyle}"/>
        </Style>

        <Style x:Key="StepCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StepCellEditingTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Sequencer" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Build, tune and run repeatable macro flows" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               Style="{StaticResource HideInCompactModeTextStyle}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewCommand}" Margin="0,0,8,0" ToolTip="Create new macro">
                        <StackPanel Orientation="Horizontal">
                            <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/file-plus.svg" Margin="0,0,6,0"/>
                            <TextBlock Text="New" Style="{StaticResource HideInCompactModeTextStyle}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenCommand}" Margin="0,0,8,0" ToolTip="Open existing macro">
                        <StackPanel Orientation="Horizontal">
                            <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/folder-open.svg" Margin="0,0,6,0"/>
                            <TextBlock Text="Open" Style="{StaticResource HideInCompactModeTextStyle}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Margin="0,0,8,0" ToolTip="Save current macro">
                        <StackPanel Orientation="Horizontal">
                            <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/save.svg" Margin="0,0,6,0"/>
                            <TextBlock Text="Save" Style="{StaticResource HideInCompactModeTextStyle}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveAsCommand}" ToolTip="Save macro as new file">
                        <StackPanel Orientation="Horizontal">
                            <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/save.svg" Margin="0,0,6,0"/>
                            <TextBlock Text="Save As" Style="{StaticResource HideInCompactModeTextStyle}"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <Expander Header="Sequencer Settings" IsExpanded="False" Foreground="{StaticResource TextPrimaryBrush}">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <TextBlock Text="Profile" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding MacroName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" IsEnabled="{Binding IsEditable}" Margin="0,0,0,10"/>
                                <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" IsEnabled="{Binding IsEditable}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock Text="Playback" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Repeat mode" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding RepeatModes}" SelectedItem="{Binding RepeatMode}" Style="{StaticResource ModernComboBoxStyle}" IsEnabled="{Binding IsEditable}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Count" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" IsEnabled="{Binding IsEditable}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Loop delay (ms)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LoopDelayMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" IsEnabled="{Binding IsEditable}" Margin="0,0,0,10"/>
                                <CheckBox Content="High precision timing" IsChecked="{Binding HighPrecisionTiming}" IsEnabled="{Binding IsEditable}" Margin="0,0,0,10"/>
                                <TextBlock Text="Start/stop hotkey" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding DataContext.PlaybackHotkeyText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Run" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                <Button Style="{StaticResource SuccessButtonStyle}" Command="{Binding PlayCommand}" Height="38" Margin="0,0,0,8" ToolTip="Start macro playback">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/play.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Play" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource DangerButtonStyle}" Command="{Binding StopCommand}" Height="38" ToolTip="Stop macro playback">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/stop.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Stop" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="State: "/>
                                    <Run Text="{Binding Status}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Expander>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Steps" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Edit the action sequence row by row" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <WrapPanel Grid.Column="1" IsEnabled="{Binding IsEditable}">
                                <Button Height="34" Margin="0,0,6,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddStepCommand}" ToolTip="Add step">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/file-plus.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" Margin="0,0,6,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DuplicateStepCommand}" ToolTip="Duplicate step">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/copy.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Duplicate" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" Margin="0,0,6,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding MoveUpCommand}" ToolTip="Move step up">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/arrow-up.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Up" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" Margin="0,0,6,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding MoveDownCommand}" ToolTip="Move step down">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/arrow-down.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Down" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteStepCommand}" ToolTip="Delete step">
                                    <StackPanel Orientation="Horizontal">
                                        <svg:SvgViewbox Width="15" Height="15" Source="/Assets/Icons/trash.svg" Margin="0,0,6,0"/>
                                        <TextBlock Text="Delete" Style="{StaticResource HideInCompactModeTextStyle}"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Grid>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Steps}"
                                  SelectedItem="{Binding SelectedStep}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  HeadersVisibility="Column"
                                                                    ColumnWidth="*"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource CardBorderBrush}"
                                  RowHeaderWidth="0"
                                  FontSize="13"
                                                                    MinColumnWidth="64"
                                  MinHeight="320"
                                                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  IsEnabled="{Binding IsEditable}">
                            <DataGrid.Columns>
                                                                <DataGridTemplateColumn Header="Type" Width="1.25*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.StepTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource StepCellComboBoxStyle}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Input" Width="1.7*" MinWidth="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding SelectableInputOptions}"
                                                      SelectedItem="{Binding KeyOrButton, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="False"
                                                      IsTextSearchEnabled="True"
                                                      StaysOpenOnEdit="False"
                                                      Style="{StaticResource StepCellComboBoxStyle}"
                                                      IsEnabled="{Binding HasSelectableInput}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Hold" Width="0.7*" MinWidth="72"
                                                    Binding="{Binding HoldMs, UpdateSourceTrigger=PropertyChanged}"
                                                    ElementStyle="{StaticResource StepCellTextStyle}"
                                                    EditingElementStyle="{StaticResource StepCellEditingTextBoxStyle}"/>
                                <DataGridTextColumn Header="Delay" Width="0.7*" MinWidth="72"
                                                    Binding="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}"
                                                    ElementStyle="{StaticResource StepCellTextStyle}"
                                                    EditingElementStyle="{StaticResource StepCellEditingTextBoxStyle}"/>
                                <DataGridTextColumn Header="X" Width="0.6*" MinWidth="64"
                                                    Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}"
                                                    ElementStyle="{StaticResource StepCellTextStyle}"
                                                    EditingElementStyle="{StaticResource StepCellEditingTextBoxStyle}"/>
                                <DataGridTextColumn Header="Y" Width="0.6*" MinWidth="64"
                                                    Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}"
                                                    ElementStyle="{StaticResource StepCellTextStyle}"
                                                    EditingElementStyle="{StaticResource StepCellEditingTextBoxStyle}"/>
                                <DataGridTextColumn Header="Description" Width="2.1*" MinWidth="180" IsReadOnly="True"
                                                    Binding="{Binding Description}"
                                                    ElementStyle="{StaticResource StepCellTextStyle}"/>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="0,12,0,0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Text="{Binding Steps.Count, StringFormat='{}{0} steps'}"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
