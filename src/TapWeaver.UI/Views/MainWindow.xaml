<Window x:Class="TapWeaver.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TapWeaver.UI.Views"
        xmlns:vm="clr-namespace:TapWeaver.UI.ViewModels"
        xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        Title="TapWeaver" Height="760" Width="1180"
        MinHeight="620" MinWidth="920"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:RecorderViewModel}">
            <views:RecorderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SequencerViewModel}">
            <views:SequencerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AutoClickerViewModel}">
            <views:AutoClickerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1F2937" Offset="0.5"/>
                <GradientStop Color="#111827" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Ellipse Grid.Row="1" Width="340" Height="340" Fill="#202196F3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0"/>
        <Ellipse Grid.Row="1" Width="300" Height="300" Fill="#164CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-70,-70"/>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#D91B2229" BorderBrush="#334155" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="10,6,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="22" Height="22" Background="#223B82F6" CornerRadius="7" Margin="0,0,8,0">
                        <Viewbox Margin="4">
                            <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/play.svg"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="TapWeaver" FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    <TextBlock Text="  studio" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"
                               Style="{StaticResource HideInCompactModeTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarActionButtonStyle}" Click="MinimizeButton_Click" ToolTip="Minimize" Margin="0,0,6,0">
                        <svg:SvgViewbox Width="12" Height="12" Source="/Assets/Icons/minimize.svg"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarActionButtonStyle}" Click="MaximizeRestoreButton_Click" ToolTip="Maximize/Restore" Margin="0,0,6,0">
                        <svg:SvgViewbox Width="12" Height="12" Source="/Assets/Icons/maximize.svg"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarActionButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                        <svg:SvgViewbox Width="12" Height="12" Source="/Assets/Icons/close.svg"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10,6,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="220" CornerRadius="14" Background="#D91B2229" BorderBrush="#334155" BorderThickness="1" Padding="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Width" Value="220"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CompactMode}" Value="True">
                                <Setter Property="Width" Value="78"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Navigation" Foreground="#94A3B8" FontSize="11" Margin="6,2,6,10"
                               Style="{StaticResource HideInCompactModeTextStyle}"/>

                    <StackPanel Grid.Row="1">
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowRecorderCommand}" Tag="{Binding IsRecorderPageSelected}" Margin="0,0,0,8" ToolTip="Recorder">
                            <StackPanel Orientation="Horizontal">
                                <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/record.svg" Margin="0,0,8,0"/>
                                <TextBlock Text="Recorder" Style="{StaticResource HideInCompactModeTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowSequencerCommand}" Tag="{Binding IsSequencerPageSelected}" Margin="0,0,0,8" ToolTip="Sequencer">
                            <StackPanel Orientation="Horizontal">
                                <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/play.svg" Margin="0,0,8,0"/>
                                <TextBlock Text="Sequencer" Style="{StaticResource HideInCompactModeTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowAutoClickerCommand}" Tag="{Binding IsAutoClickerPageSelected}" Margin="0,0,0,8" ToolTip="Auto Clicker">
                            <StackPanel Orientation="Horizontal">
                                <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/crosshair.svg" Margin="0,0,8,0"/>
                                <TextBlock Text="Auto Clicker" Style="{StaticResource HideInCompactModeTextStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowSettingsCommand}" Tag="{Binding IsSettingsPageSelected}" ToolTip="Settings">
                            <StackPanel Orientation="Horizontal">
                                <svg:SvgViewbox Width="14" Height="14" Source="/Assets/Icons/settings.svg" Margin="0,0,8,0"/>
                                <TextBlock Text="Settings" Style="{StaticResource HideInCompactModeTextStyle}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <CheckBox IsChecked="{Binding AlwaysOnTop}" Content="Always on top" Foreground="#CBD5E1" FontSize="11" Margin="2,0,0,6"/>
                        <CheckBox IsChecked="{Binding UseDarkMode}" Content="Dark mode" Foreground="#CBD5E1" FontSize="11" Margin="2,0,0,6"/>
                        <CheckBox IsChecked="{Binding CompactMode}" Content="Compact" Foreground="#CBD5E1" FontSize="11" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Column="2" Content="{Binding CurrentPageViewModel}"/>
        </Grid>
    </Grid>
</Window>
