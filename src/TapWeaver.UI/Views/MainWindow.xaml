<Window x:Class="TapWeaver.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TapWeaver.UI.Views"
        xmlns:vm="clr-namespace:TapWeaver.UI.ViewModels"
        Title="TapWeaver" Height="760" Width="1180"
        MinHeight="620" MinWidth="920"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Area -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TapWeaver" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="  Modern Macro Studio" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Always-on-top quick-toggle in title bar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding AlwaysOnTop}" Content="Always on top"
                              VerticalAlignment="Center" FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              ToolTip="Keep this window above all other windows"
                              Margin="0,0,14,0"/>
                    <CheckBox IsChecked="{Binding UseDarkMode}" Content="Dark mode"
                              VerticalAlignment="Center" FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              ToolTip="Switch between light and dark UI theme"
                              Margin="0,0,14,0"/>
                    <CheckBox IsChecked="{Binding CompactMode}" Content="Compact"
                              VerticalAlignment="Center" FontSize="12"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              ToolTip="Condense UI for a TinyTask-like small workspace"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}" Margin="8,6,8,8">
            <TabItem Header="{Binding RecorderTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:RecorderView DataContext="{Binding Recorder}"/>
            </TabItem>
            <TabItem Header="{Binding SequencerTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:SequencerView DataContext="{Binding Sequencer}"/>
            </TabItem>
            <TabItem Header="{Binding AutoClickerTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:AutoClickerView DataContext="{Binding AutoClicker}"/>
            </TabItem>
            <TabItem Header="{Binding SettingsTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
