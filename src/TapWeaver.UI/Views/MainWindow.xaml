<Window x:Class="TapWeaver.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TapWeaver.UI.Views"
        xmlns:vm="clr-namespace:TapWeaver.UI.ViewModels"
        Title="TapWeaver" Height="700" Width="1000"
        MinHeight="600" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Area -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TapWeaver" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="  -  Macro Recorder and Auto Clicker" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}">
            <TabItem Header="Recorder" Style="{StaticResource ModernTabItem}">
                <views:RecorderView DataContext="{Binding Recorder}"/>
            </TabItem>
            <TabItem Header="Sequencer" Style="{StaticResource ModernTabItem}">
                <views:SequencerView DataContext="{Binding Sequencer}"/>
            </TabItem>
            <TabItem Header="Auto Clicker" Style="{StaticResource ModernTabItem}">
                <views:AutoClickerView DataContext="{Binding AutoClicker}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
