<Window x:Class="TapWeaver.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TapWeaver.UI.Views"
        xmlns:vm="clr-namespace:TapWeaver.UI.ViewModels"
        Title="TapWeaver" Height="760" Width="1180"
        MinHeight="620" MinWidth="920"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1F2937" Offset="0.5"/>
                <GradientStop Color="#111827" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Ellipse Width="420" Height="420" Fill="#262196F3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-120,0,0"/>
        <Ellipse Width="360" Height="360" Fill="#1A4CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-90,-90"/>

        <!-- Title Bar Area -->
        <Border Grid.Row="0" Background="#D91B2229" BorderBrush="#334155" BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TapWeaver" FontSize="20" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    <TextBlock Text="  Modern Macro Studio" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"
                               Style="{StaticResource HideInCompactModeTextStyle}"/>
                </StackPanel>
                <!-- Always-on-top quick-toggle in title bar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding AlwaysOnTop}" Content="Always on top"
                              VerticalAlignment="Center" FontSize="12"
                              Foreground="#CBD5E1"
                              ToolTip="Keep this window above all other windows"
                              Margin="0,0,14,0"/>
                    <CheckBox IsChecked="{Binding UseDarkMode}" Content="Dark mode"
                              VerticalAlignment="Center" FontSize="12"
                              Foreground="#CBD5E1"
                              ToolTip="Switch between light and dark UI theme"
                              Margin="0,0,14,0"/>
                    <CheckBox IsChecked="{Binding CompactMode}" Content="Compact"
                              VerticalAlignment="Center" FontSize="12"
                              Foreground="#CBD5E1"
                              ToolTip="Condense UI for a TinyTask-like small workspace"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <Border Grid.Row="1" Margin="10,8,10,10" CornerRadius="16" Background="#D91B2229" BorderBrush="#334155" BorderThickness="1" Padding="6">
        <TabControl Style="{StaticResource ModernTabControl}" Margin="2">
            <TabItem Header="{Binding RecorderTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:RecorderView DataContext="{Binding Recorder}"/>
            </TabItem>
            <TabItem Header="{Binding SequencerTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:SequencerView DataContext="{Binding Sequencer}"/>
            </TabItem>
            <TabItem Header="{Binding AutoClickerTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:AutoClickerView DataContext="{Binding AutoClicker}"/>
            </TabItem>
            <TabItem Header="{Binding SettingsTabHeader}" Style="{StaticResource ModernTabItem}">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>
        </Border>
    </Grid>
</Window>
